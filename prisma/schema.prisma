generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  MODERATOR
  ADMIN
}

// ─────────────────────────────────────────────
// Пользователь
// ─────────────────────────────────────────────
model User {
  id                       BigInt  @id @default(autoincrement())
  // Telegram user ID — nullable, чтобы web-only юзеры существовали без привязки бота.
  // У существующих/линкованных юзеров `telegramId` совпадает с историческим `id`
  // (backfill в миграции). Все Telegram-операции (chat_id, ctx.from.id lookup) и
  // записи `WelcomeBonusReceipt` / `GrantedMetaboxOrder` (ключ без FK) — по `telegramId`.
  telegramId               BigInt? @unique
  username                 String?
  firstName                String?
  lastName                 String?
  language                 String  @default("en")
  role                     Role    @default(USER)
  tokenBalance             Decimal @default(0) @db.Decimal(12, 4)
  subscriptionTokenBalance Decimal @default(0) @db.Decimal(12, 4)
  isNew                    Boolean @default(true)
  isBlocked                Boolean @default(false)
  referredById             BigInt?
  metaboxUserId            String? @unique // UUID пользователя в Metabox (после привязки)
  metaboxReferralCode      String? // Реферальный код Metabox (кешируется при привязке)
  finishedOnboarding       Boolean @default(false)
  generationCount          Int     @default(0)
  confirmBeforeGenerate    Boolean @default(true)
  autoActivateModel        Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  referredBy        User?              @relation("Referrals", fields: [referredById], references: [id], onDelete: SetNull)
  referrals         User[]             @relation("Referrals")
  dialogs           Dialog[]
  transactions      TokenTransaction[]
  userState         UserState?
  uploads           UserUpload[]
  userAvatars       UserAvatar[]
  userVoices        UserVoice[]
  localSubscription LocalSubscription?
  galleryFolders    GalleryFolder[]
  pendingGeneration PendingGeneration?
  generationJobs    GenerationJob[]
  webNotifications  WebNotification[]
  uploadedMedia     UploadedMedia[]
  elements          Element[]

  @@map("users")
}

// ─────────────────────────────────────────────
// Подтверждение перед запуском генерации (Низкий IQ мод).
// Один pending-запрос на пользователя — на новом промте upsert перезаписывает
// предыдущий. Cleanup по expiresAt раз в N минут крон-монитором воркера.
// ─────────────────────────────────────────────
model PendingGeneration {
  id            String   @id @default(cuid())
  userId        BigInt   @unique
  section       String // image | video | audio
  modelId       String
  prompt        String
  payload       Json // SubmitImage/Video/AudioParams для replay
  estimatedCost Decimal  @db.Decimal(12, 4)
  chatId        BigInt
  messageId     BigInt
  expiresAt     DateTime
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([expiresAt])
  @@map("pending_generations")
}

// Состояние FSM бота для пользователя
model UserState {
  userId     BigInt  @id
  state      String  @default("IDLE") // IDLE | MAIN_MENU | GPT_SECTION | GPT_ACTIVE | ...
  section    String? // gpt | design | audio | video
  gptModelId String? // текущая выбранная GPT-модель

  // Активный диалог для каждого раздела (хранится независимо)
  gptDialogId    String?
  designDialogId String?
  audioDialogId  String?
  videoDialogId  String?

  // Выбранная модель для каждого медиа-раздела (не зависит от диалога)
  designModelId String?
  audioModelId  String?
  videoModelId  String?

  // Референс для img2img: Message.id выбранного изображения (one-shot, сбрасывается после использования)
  designRefMessageId String?

  // Референс-фото для D-ID lip-sync: Telegram file URL (one-shot, сбрасывается после использования)
  videoRefImageUrl String?

  // Референс-видео для D-ID driver_url: Telegram file URL (one-shot, сбрасывается после использования)
  videoRefDriverUrl String?

  // Голосовое сообщение для HeyGen audio voice: Telegram file URL (one-shot, сбрасывается после использования)
  videoRefVoiceUrl String?

  // Длительность последнего загруженного юзером аудио для HeyGen voice_audio
  // слота (в секундах, ffprobe'нута на байтах при загрузке — не доверяем
  // metadata-полю Telegram audio messages, чтобы не было billing-exploit'а).
  // Используется как `audioDurationSecHint` в cost-preview, чтобы не падать
  // в per_second режим из-за flaky probe в submit-time. Перезаписывается на
  // каждой новой загрузке voice'а; не очищается при сабмите — `hasVoiceAudio`
  // guard в боте отсекает stale значения когда mediaInputs.voice_audio пуст.
  videoVoiceDurationSec Int?

  // Настройки генерации изображений: { [modelId]: { aspectRatio: string } }
  imageSettings Json?

  // Настройки генерации видео: { [modelId]: { aspectRatio?: string; duration?: number } }
  videoSettings Json?

  // Произвольные настройки моделей: { [modelId]: { [key]: string | number | boolean | null } }
  modelSettings Json?

  // Медиа-входы для генерации: { [modelId]: { [slotKey]: string[] } } — независимы для каждой модели;
  // сбрасываются только при старте генерации (текущая модель) или ручном удалении.
  // Также используется для буфера фотографий при создании персонажа Higgsfield Soul под ключом
  // "soul_creation" (file_id без TTL, resolve → S3 на submit).
  mediaInputs Json?

  // Выбранный режим работы модели: { [modelId]: modeId } — например { "veo": "i2v" }.
  // Независим для каждой модели, влияет на набор показанных media-слотов.
  selectedModes Json?

  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_states")
}

// ─────────────────────────────────────────────
// Диалоги
// ─────────────────────────────────────────────
model Dialog {
  id        String  @id @default(cuid())
  userId    BigInt
  section   String // gpt | design | audio | video
  modelId   String // gpt-4o | claude-sonnet | midjourney | kling | etc.
  title     String?
  isDeleted Boolean @default(false)

  // ── Стратегия хранения контекста ────────────────────────────────────────
  // "provider_chain"  — OpenAI Responses API: цепочка через previous_response_id
  // "provider_thread" — OpenAI Assistants: сервер хранит всю историю в Thread
  // "db_history"      — Anthropic, Gemini и др.: история из БД, последние N сообщений
  contextStrategy           String  @default("db_history")
  providerThreadId          String? // OpenAI Assistants: thread_id
  providerLastResponseId    String? // OpenAI Responses API: последний response_id
  // ProviderKey.id, чьим ключом был создан providerLastResponseId. OpenAI
  // response_id привязан к организации/аккаунту — при смене ключа (другой
  // org/аккаунт) старый response_id невалиден. Если на следующем turn'е
  // выбран другой ключ, chat-сервис дропает previousResponseId и шлёт полную
  // историю. null = env-fallback или ключ удалён.
  providerLastResponseKeyId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages Message[]

  @@index([userId])
  @@index([userId, section])
  @@map("dialogs")
}

model Message {
  id                String  @id @default(cuid())
  dialogId          String
  role              String // user | assistant
  content           String
  mediaUrl          String?
  mediaType         String? // image | video | audio
  attachments       Json? // [{ s3Key, mimeType, name, size }] — documents attached to the message
  tokensUsed        Decimal @default(0) @db.Decimal(10, 4)
  inputTokens       Int     @default(0) // raw provider input tokens (assistant messages only; 0 для user)
  outputTokens      Int     @default(0) // raw provider output tokens (assistant messages only; 0 для user)
  providerMessageId String? // OpenAI Assistants: message_id (для управления историей)
  failed            Boolean @default(false) // true if the LLM request failed; excluded from history

  createdAt DateTime @default(now())

  dialog Dialog @relation(fields: [dialogId], references: [id], onDelete: Cascade)

  @@index([dialogId, createdAt])
  @@map("messages")
}

// ─────────────────────────────────────────────
// Токены
// ─────────────────────────────────────────────
model TokenTransaction {
  id          String  @id @default(cuid())
  userId      BigInt
  amount      Decimal @db.Decimal(12, 4) // положительное = пополнение, отрицательное = списание
  type        String // credit | debit
  reason      String // welcome_bonus | ai_usage | purchase | referral_bonus | admin | metabox_purchase
  description String? // Человекочитаемое описание (напр. "Подписка PRO (M3)")

  // Метаданные для разных типов
  modelId  String? // при ai_usage — primary modelId (по нему считалась цена с коэффициентами)
  dialogId String? // при ai_usage

  /**
   * Фактически использованный провайдер (отличается от model.provider при
   * fallback'е). Заполняется на ai_usage / autotranslate / describe_image
   * и прочих debit'ах, связанных с провайдер-вызовом. null для не-AI
   * транзакций и старых записей до миграции.
   */
  actualProvider String?
  /**
   * Оценка фактической цены запроса в USD на actualProvider — БЕЗ применения
   * pricing-коэффициентов (per-model multiplier, target margin). Сырая
   * provider-side стоимость (= mediaUsd + inputImageUsd + addonUsd + llmUsd
   * по модели actualProvider'а). Для аудита фактических расходов / маржи.
   */
  actualCostUsd  Decimal? @db.Decimal(12, 6)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("token_transactions")
}

// ─────────────────────────────────────────────
// Задачи генерации (async queue)
// ─────────────────────────────────────────────
model GenerationJob {
  id       String @id @default(cuid())
  userId   BigInt
  dialogId String
  section  String // image | video | audio
  modelId  String
  status   String @default("pending") // pending | processing | done | failed

  prompt           String
  inputData        Json? // доп. параметры (размер, стиль и т.д.)
  providerJobId    String? // external provider task ID — persisted after submit for poll resume on restart
  providerKeyId    String? // ProviderKey.id выбранный на submit; null = был использован env-fallback
  sourceMessageId  String? // "{chatId}:{messageId}" of the inline button that triggered this job
  pollStartedAt    DateTime? // момент перехода в poll-стадию — фиксируется при записи providerJobId, чтобы 24ч-таймаут корректно работал после recovery
  tokensSpent      Decimal?  @db.Decimal(12, 4) // сколько внутренних токенов списано за эту джобу (для отображения в галерее); null = неизвестно (старые джобы или recovery fast-path)
  // Сырое exception-сообщение для ops/debugging. Никогда не показывается
  // пользователю напрямую — для UI используется `errorUserMessage` ниже.
  error            String?
  // Локализованное user-facing сообщение об ошибке (из `resolveUserFacingMessage`
  // / `pickGenerationFailedMessage`). То же, что бот шлёт в чат и что пишется
  // в WS-нотификацию. Web-UI читает это поле для истории генераций. null =
  // job ещё не упал или старая job до выкатки колонки.
  errorUserMessage String?
  // Структурированная категория ошибки для статистики. Значения — из
  // `GenerationErrorCode` в `packages/shared/src/error-codes.ts`:
  // INPUT_MODERATION, OUTPUT_MODERATION, INPUT_VALIDATION, INPUT_MEDIA_FORMAT,
  // INPUT_MEDIA_SIZE, INPUT_MEDIA_QUALITY, INPUT_INCOMPATIBLE,
  // FEATURE_NOT_SUPPORTED, RATE_LIMIT_SHORT, RATE_LIMIT_LONG,
  // PROVIDER_UNAVAILABLE, PROVIDER_AUTH, PROVIDER_INSUFFICIENT_CREDIT,
  // USER_BLOCKED, AVATAR_VOICE_NOT_FOUND, NETWORK_TRANSIENT, POLL_TIMEOUT,
  // NO_RESULT, INTERNAL_ERROR, UNKNOWN.
  // Хранится строкой (не enum'ом) для forward-compat: новые коды можно
  // добавлять в TS без миграции. null = ошибки нет ИЛИ старая джоба
  // (до выкатки этой колонки).
  errorCode        String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  outputs          GenerationJobOutput[]
  webNotifications WebNotification[]

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([userId, sourceMessageId, status])
  @@index([errorCode]) // GROUP BY в admin-аналитике по видам отказов
  @@map("generation_jobs")
}

// ─────────────────────────────────────────────
// Персистентные уведомления для веб-фронта (packages/web).
// Дополняют эфемерный Redis pub/sub `job-notifications`: если фронт офлайн в
// момент завершения джобы — событие сохраняется и подтянется при следующем
// заходе в личный кабинет.
// type: image_success | image_error | video_success | video_error | audio_success | audio_error
// data — payload из JobNotificationMessage (outputs[], errorCode, partial, ...).
// ─────────────────────────────────────────────
model WebNotification {
  id      String  @id @default(cuid())
  userId  BigInt
  jobId   String?
  type    String
  title   String
  message String
  isSeen  Boolean @default(false)
  data    Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  GenerationJob? @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, isSeen])
  @@index([jobId])
  @@map("web_notifications")
}

model GenerationJobOutput {
  id             String  @id @default(cuid())
  jobId          String
  index          Int     @default(0) // 0-based order within batch
  outputUrl      String?
  s3Key          String?
  thumbnailS3Key String?

  createdAt DateTime @default(now())

  job         GenerationJob       @relation(fields: [jobId], references: [id], onDelete: Cascade)
  folderItems GalleryFolderItem[]

  @@unique([jobId, index]) // защита от дубликата при stalled-redelivery race в finalize
  @@index([jobId])
  @@map("generation_job_outputs")
}

// ─────────────────────────────────────────────
// Загрузки пользователей (голоса, аудио)
// ─────────────────────────────────────────────
model UserUpload {
  id     String  @id @default(cuid())
  userId BigInt
  type   String // "voice" | "audio"
  name   String
  url    String // публичный URL (S3 или Telegram)
  s3Key  String? // ключ в S3, если файл загружен

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_uploads")
}

// ─────────────────────────────────────────────
// Загруженные пользователем медиа (для попапа «переиспользовать загруженное»).
// Запись создаётся на каждый upload image/video/audio через POST /web/chat-uploads
// (документы не сохраняются). Удаление записи НЕ удаляет S3-объект — тот же s3Key
// может быть в отправленном Message.attachments или в чужом черновике генерации.
// ─────────────────────────────────────────────
model UploadedMedia {
  id        String   @id @default(cuid())
  userId    BigInt
  type      String // image | video | audio
  s3Key     String
  name      String
  mimeType  String
  size      Int
  createdAt DateTime @default(now())
  // Если задан — медиа принадлежит пользовательскому Element'у (набору референсов)
  // и НЕ показывается в общем списке переиспользования (uploadedMediaService.list
  // фильтрует elementId IS NULL).
  elementId String?

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  element Element? @relation(fields: [elementId], references: [id], onDelete: Cascade)

  // Курсорная пагинация по новизне: cuid монотонен, id desc ≈ createdAt desc.
  @@index([userId, id(sort: Desc)])
  @@index([userId, type, id(sort: Desc)])
  @@index([elementId])
  @@map("uploaded_media")
}

// ─────────────────────────────────────────────
// Element — именованный (@-тег) набор референсных изображений, который юзер
// создаёт для себя и подставляет в промпт моделей с @-синтаксисом (Kling и т.п.).
// Картинки — это строки UploadedMedia с проставленным elementId; удаление
// элемента каскадит их (S3-объекты не трогаем, как и при обычном удалении media).
// ─────────────────────────────────────────────
model Element {
  id        String   @id @default(cuid())
  userId    BigInt
  name      String // @-тег без символа @, валидация ^[a-zA-Z0-9_]+$
  createdAt DateTime @default(now())

  user  User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  media UploadedMedia[]

  @@unique([userId, name])
  @@index([userId, id(sort: Desc)])
  @@map("elements")
}

// ─────────────────────────────────────────────
// Пользовательские аватары (кастомные, создаются через провайдеры)
// ─────────────────────────────────────────────
model UserAvatar {
  id            String   @id @default(cuid())
  userId        BigInt
  provider      String // "heygen" | "higgsfield_soul"
  name          String
  externalId    String? // talking_photo_id (HeyGen) / Soul ID
  previewUrl    String?
  status        String   @default("creating") // "creating" | "ready" | "failed" | "orphaned"
  // ProviderKey, на котором был создан внешний ресурс. Внешние provider-айди
  // (talking_photo_id и т.п.) живут в аккаунте конкретного API-ключа, поэтому
  // потреблять их можно только тем же ключом. null = был использован env-fallback.
  providerKeyId String?
  // Исходные s3-ключи фото, из которых обучается Soul-персонаж. Заполняются
  // при создании аватара через web-приложение (когда мы держим pending-record
  // в status="creating" до того, как worker отправит их в Higgsfield Soul API).
  // Для HeyGen остаётся пустым массивом — там аплоад синхронный, исходник
  // потребляется сразу адаптером.
  sourceS3Keys  String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerKey ProviderKey? @relation(fields: [providerKeyId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, provider])
  @@index([providerKeyId])
  @@map("user_avatars")
}

// ─────────────────────────────────────────────
// Пользовательские голоса (клонированные через ElevenLabs)
// ─────────────────────────────────────────────
model UserVoice {
  id            String    @id @default(cuid())
  userId        BigInt
  provider      String // "elevenlabs"
  name          String
  externalId    String? // ElevenLabs voice_id
  previewUrl    String?
  audioS3Key    String? // S3 key of the original audio — used to recreate the voice if EL slot is lost
  status        String    @default("ready") // "ready" | "failed"
  lastUsedAt    DateTime? // updated on each TTS generation — used for LRU eviction
  // Аккаунт ElevenLabs, в котором сейчас живёт voice_id. При утере (ключ удалён
  // из пула, slot выселен) — пересоздаём из audioS3Key на любом активном ключе
  // и обновляем это поле + externalId.
  providerKeyId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  providerKey ProviderKey? @relation(fields: [providerKeyId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, provider])
  @@index([providerKeyId])
  @@map("user_voices")
}

// ─────────────────────────────────────────────
// Баннерные слайды
// ─────────────────────────────────────────────
model BannerSlide {
  id             String  @id @default(cuid())
  imageUrl       String
  linkUrl        String?
  displaySeconds Int     @default(4)
  sortOrder      Int     @default(0)
  active         Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([active, sortOrder])
  @@map("banner_slides")
}

// ─────────────────────────────────────────────
// Локальная подписка (сохраняется при отвязке от сайта)
// ─────────────────────────────────────────────
model LocalSubscription {
  id                    String   @id @default(cuid())
  userId                BigInt   @unique
  planName              String
  period                String // M1 | M3 | M6 | M12
  tokensGranted         Int
  endDate               DateTime
  startDate             DateTime
  isActive              Boolean  @default(true)
  /// AiBoxSubscription.id from Metabox site — used for idempotency on grant-tokens
  metaboxSubscriptionId String?  @unique

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("local_subscriptions")
}

// Папки галереи (пользовательские коллекции)
// ─────────────────────────────────────────────
model GalleryFolder {
  id        String    @id @default(cuid())
  userId    BigInt
  name      String
  isDefault Boolean   @default(false) // true = Избранное — нельзя переименовать/удалить
  isPinned  Boolean   @default(false)
  pinnedAt  DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user  User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  items GalleryFolderItem[]

  @@index([userId])
  @@map("gallery_folders")
}

model GalleryFolderItem {
  folderId String
  outputId String
  addedAt  DateTime @default(now())

  folder GalleryFolder       @relation(fields: [folderId], references: [id], onDelete: Cascade)
  output GenerationJobOutput @relation(fields: [outputId], references: [id], onDelete: Cascade)

  @@id([folderId, outputId])
  @@index([outputId])
  @@map("gallery_folder_items")
}

// ─────────────────────────────────────────────
// Курс обмена (USDT/RUB)
// ─────────────────────────────────────────────
model ExchangeRate {
  pair      String   @id // "USDT_RUB"
  rate      Decimal  @db.Decimal(12, 4)
  updatedAt DateTime @updatedAt

  @@map("exchange_rates")
}

// ─────────────────────────────────────────────
// Прокси (для маршрутизации запросов к AI-провайдерам)
// ─────────────────────────────────────────────
model Proxy {
  id             String  @id @default(cuid())
  label          String // человекочитаемое имя ("DE-1", "US-East")
  protocol       String // "http" | "https" | "socks5"
  host           String
  port           Int
  username       String? // зашифрованный (AES-GCM ciphertext, base64) — может быть null
  passwordCipher String? // зашифрованный пароль
  isActive       Boolean @default(true)
  notes          String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  keys ProviderKey[]

  @@map("proxies")
}

// ─────────────────────────────────────────────
// API-ключи провайдеров (пул с балансировкой)
// ─────────────────────────────────────────────
model ProviderKey {
  id        String  @id @default(cuid())
  provider  String // "openai" | "anthropic" | "google" | "fal" | ...
  label     String // "OpenAI Main", "OpenAI Backup #1"
  keyCipher String // AES-GCM ciphertext значения ключа (base64)
  keyMask   String // последние 4 символа для UI ("…1234")
  proxyId   String?
  priority  Int     @default(0) // выше = приоритетнее (берётся первым)
  isActive  Boolean @default(true)
  notes     String?

  // Метрики (best-effort)
  requestCount  BigInt    @default(0)
  errorCount    BigInt    @default(0)
  lastUsedAt    DateTime?
  lastErrorAt   DateTime?
  lastErrorText String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  proxy       Proxy?       @relation(fields: [proxyId], references: [id], onDelete: SetNull)
  userVoices  UserVoice[]
  userAvatars UserAvatar[]

  @@index([provider, isActive, priority])
  @@map("provider_keys")
}

// ─────────────────────────────────────────────
// Runtime price overrides — управляются из админки.
// scope="model": множитель для конкретной модели (key=modelId, multiplier ~ 0.5..2).
// scope="global": override для config.billing.targetMargin (key="targetMargin").
// Пустая таблица = поведение полностью идентично env-конфигу (multiplier=1, margin=config).
// ─────────────────────────────────────────────
model PricingOverride {
  id         String   @id @default(cuid())
  scope      String // "model" | "global"
  key        String // model.id для scope="model", "targetMargin" для scope="global"
  multiplier Decimal  @db.Decimal(6, 4)
  note       String?
  updatedBy  String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([scope, key])
  @@map("pricing_overrides")
}

// ─────────────────────────────────────────────
// Идемпотентность зачисления токенов по AiBotOrder со стороны Metabox.
//
// Сценарии double-credit'а, которые этим блокируем:
//  1. Metabox дёрнул /grant-tokens с orderId X → бот зачислил и записал
//     GrantedMetaboxOrder, но HTTP-ответ потерялся → Metabox ретраит →
//     второй вызов на /grant-tokens увидит запись и no-op'нет.
//  2. /start запускает syncMetaboxGrants → бот успел зачислить + создать
//     запись, но mark-order-granted на metabox-стороне упал → AiBotOrder
//     остался tokensGrantedToBot=false → следующий /start снова приходит
//     в getPendingTokenGrants → пред-чек видит запись, скипает зачисление,
//     только дёргает mark-order-granted (чистит metabox-state).
//  3. /grant-tokens и syncMetaboxGrants пересеклись на одном order'е —
//     один из путей упадёт на unique-violation orderId и откатит транзакцию.
//
// Без FK на User — запись переживает удаление аккаунта (account-deletion),
// иначе после deletion + повторного /start metabox мог бы повторно выдать
// уже зачислявшийся order. Ключ — AiBotOrder.id (cuid), глобально уникален
// на metabox-стороне.
//
// Аналог по подпискам — LocalSubscription.metaboxSubscriptionId
// (используется в grantMetaboxSubscription как ALREADY_GRANTED check).
// ─────────────────────────────────────────────
model GrantedMetaboxOrder {
  orderId     String   @id
  // Nullable: web-only юзеры (создан через ai.metabox.global без TG-привязки)
  // тоже получают token-grants синком, и для них telegramId отсутствует.
  // Дедуп всё равно работает по orderId как PK.
  telegramId  BigInt?
  tokens      Decimal  @db.Decimal(12, 4)
  description String?
  grantedAt   DateTime @default(now())

  @@index([telegramId])
  @@map("granted_metabox_orders")
}

// ─────────────────────────────────────────────
// Учёт выдач welcome-бонуса.
// Намеренно БЕЗ foreign key на User — запись должна пережить cascade-удаление
// аккаунта (см. account-deletion.service.ts), иначе после deletion + повторного
// /start юзер получит welcome-бонус заново. Ключ — telegramId, который
// неизменен и не переиспользуется Telegram'ом.
// ─────────────────────────────────────────────
model WelcomeBonusReceipt {
  telegramId BigInt   @id
  amount     Decimal  @db.Decimal(12, 4)
  creditedAt DateTime @default(now())

  @@map("welcome_bonus_receipts")
}

// ─────────────────────────────────────────────
// Архивные записи удалённых аккаунтов.
// Юзер копируется сюда снапшотом перед каскадным удалением из `users`.
// pendingMetaboxTransfer=true => перенос tokens/subscription на metabox-аккаунт
// не прошёл (404/network/etc) — снапшот localSubscriptionSnapshot хранит данные
// для последующего ручного / cron-reconcile.
// ─────────────────────────────────────────────
model DeletedUser {
  id                        String   @id @default(cuid())
  // НЕ unique: один и тот же telegramId может удалиться несколько раз
  // (юзер удалил аккаунт → /start создаёт новый → снова удаляет). Каждое
  // удаление — отдельный snapshot для аудита и retry-reconcile.
  // Nullable: web-only юзер мог удалить аккаунт без TG-привязки.
  telegramId                BigInt?
  username                  String?
  firstName                 String?
  lastName                  String?
  language                  String
  metaboxUserId             String?
  metaboxReferralCode       String?
  tokenBalance              Decimal  @db.Decimal(12, 4)
  subscriptionTokenBalance  Decimal  @db.Decimal(12, 4)
  hadLocalSubscription      Boolean  @default(false)
  localSubscriptionSnapshot Json?
  pendingMetaboxTransfer    Boolean  @default(false)
  transferError             String?
  originalCreatedAt         DateTime
  deletedAt                 DateTime @default(now())

  @@index([telegramId])
  @@index([metaboxUserId])
  @@index([pendingMetaboxTransfer])
  @@map("deleted_users")
}

model PromptExample {
  id String @id @default(cuid())

  modelId       String
  modelSettings Json?

  prompt String

  mediaS3Key     String?
  thumbnailS3Key String?

  section String // image | video | audio

  createdAt DateTime @default(now())

  // will use cursor pagination for infinite scrolling, so indexes by section and id
  @@index([section, id(sort: Desc)])
  @@map("prompt_examples")
}
