{
  "openapi": "3.0.4",
  "info": {
    "title": "Queue OpenAPI for fal-ai/hy-wu-edit",
    "version": "1.0.0",
    "description": "The OpenAPI schema for the fal-ai/hy-wu-edit queue.",
    "x-fal-metadata": {
      "endpointId": "fal-ai/hy-wu-edit",
      "category": "image-to-image",
      "thumbnailUrl": "https://v3b.fal.media/files/b/0a93a35a/UbYPmsk9O9i9-oWlUKVYR_4e9ae612eac3475090719209add67cfd.jpg",
      "playgroundUrl": "https://fal.ai/models/fal-ai/hy-wu-edit",
      "documentationUrl": "https://fal.ai/models/fal-ai/hy-wu-edit/api",
      "about": "Generate"
    }
  },
  "components": {
    "securitySchemes": {
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "Authorization",
        "description": "Fal Key"
      }
    },
    "schemas": {
      "QueueStatus": {
        "type": "object",
        "properties": {
          "status": { "type": "string", "enum": ["IN_QUEUE", "IN_PROGRESS", "COMPLETED"] },
          "request_id": { "type": "string", "description": "The request id." },
          "response_url": { "type": "string", "description": "The response url." },
          "status_url": { "type": "string", "description": "The status url." },
          "cancel_url": { "type": "string", "description": "The cancel url." },
          "logs": { "type": "object", "description": "The logs.", "additionalProperties": true },
          "metrics": {
            "type": "object",
            "description": "The metrics.",
            "additionalProperties": true
          },
          "queue_position": { "type": "integer", "description": "The queue position." }
        },
        "required": ["status", "request_id"]
      },
      "HyWuEditInput": {
        "x-fal-order-properties": [
          "prompt",
          "image_urls",
          "image_size",
          "num_inference_steps",
          "seed",
          "num_images",
          "enable_thinking",
          "enable_safety_checker",
          "output_format",
          "sync_mode"
        ],
        "type": "object",
        "title": "HYWUEditInput",
        "properties": {
          "enable_safety_checker": {
            "type": "boolean",
            "default": true,
            "description": "If set to true, the safety checker will be enabled.",
            "title": "Enable Safety Checker"
          },
          "sync_mode": {
            "type": "boolean",
            "default": false,
            "description": "If True, the media will be returned as a data URI.",
            "title": "Sync Mode"
          },
          "num_inference_steps": {
            "maximum": 100,
            "minimum": 1,
            "type": "integer",
            "default": 30,
            "description": "Number of diffusion denoising steps.",
            "title": "Num Inference Steps"
          },
          "prompt": {
            "type": "string",
            "title": "Prompt",
            "description": "The text prompt describing the desired edit. Supports both English and Chinese. Use specific instructions like 'Replace the clothing on figure 1 with the outfit from figure 2'.",
            "examples": [
              "Using image 1 as the base image, replace the outfit with the clothing from image 2 while keeping the subject, pose, and background unchanged."
            ]
          },
          "num_images": {
            "maximum": 4,
            "minimum": 1,
            "type": "integer",
            "default": 1,
            "description": "The number of images to generate.",
            "title": "Num Images"
          },
          "image_urls": {
            "items": { "type": "string" },
            "type": "array",
            "title": "Image Urls",
            "description": "URLs of input images for editing. Typically 2 images: the base image and the reference image. Supports up to 3 images.",
            "examples": [
              [
                "https://v3b.fal.media/files/b/0a933dff/BE-FgBximAbCJzZSgDNNw_input_1_1.png",
                "https://v3b.fal.media/files/b/0a933dff/fNUqzO_Lxwvr-_-4BLeCV_input_1_2.png"
              ]
            ]
          },
          "seed": {
            "title": "Seed",
            "anyOf": [{ "type": "integer" }, { "type": "null" }],
            "description": "Random seed for reproducible results. If None, a random seed is used."
          },
          "output_format": {
            "type": "string",
            "default": "png",
            "description": "The format of the generated image.",
            "title": "Output Format",
            "enum": ["jpeg", "png"]
          },
          "image_size": {
            "title": "Image Size",
            "default": "auto",
            "description": "The desired size of the generated image. If auto, image size will be determined by the model.",
            "anyOf": [
              { "$ref": "#/components/schemas/ImageSize" },
              {
                "type": "string",
                "enum": [
                  "auto",
                  "square_hd",
                  "square",
                  "portrait_4_3",
                  "portrait_16_9",
                  "landscape_4_3",
                  "landscape_16_9"
                ]
              }
            ]
          },
          "enable_thinking": {
            "type": "boolean",
            "default": true,
            "description": "Enable thinking mode. The model reasons about the edit before generating, producing higher quality results at the cost of longer inference time. Disable for faster results on straightforward edits.",
            "title": "Enable Thinking"
          }
        },
        "required": ["prompt", "image_urls"]
      },
      "HyWuEditOutput": {
        "x-fal-order-properties": ["images", "seed", "timings"],
        "type": "object",
        "title": "HYWUEditOutput",
        "properties": {
          "images": {
            "items": { "$ref": "#/components/schemas/Image" },
            "type": "array",
            "title": "Images",
            "description": "A list of the generated/edited images."
          },
          "timings": {
            "type": "object",
            "default": {},
            "additionalProperties": { "type": "number" },
            "title": "Timings",
            "description": "Performance timing breakdown."
          },
          "seed": {
            "type": "integer",
            "title": "Seed",
            "description": "The seed used for generation."
          }
        },
        "required": ["images", "seed"]
      },
      "ImageSize": {
        "x-fal-order-properties": ["width", "height"],
        "type": "object",
        "title": "ImageSize",
        "properties": {
          "height": {
            "maximum": 14142,
            "type": "integer",
            "exclusiveMinimum": 0,
            "description": "The height of the generated image.",
            "default": 512,
            "title": "Height"
          },
          "width": {
            "maximum": 14142,
            "type": "integer",
            "exclusiveMinimum": 0,
            "description": "The width of the generated image.",
            "default": 512,
            "title": "Width"
          }
        }
      },
      "Image": {
        "x-fal-order-properties": [
          "url",
          "content_type",
          "file_name",
          "file_size",
          "width",
          "height"
        ],
        "type": "object",
        "title": "Image",
        "properties": {
          "height": {
            "title": "Height",
            "anyOf": [{ "type": "integer" }, { "type": "null" }],
            "description": "The height of the image in pixels.",
            "examples": [1024]
          },
          "content_type": {
            "title": "Content Type",
            "anyOf": [{ "type": "string" }, { "type": "null" }],
            "description": "The mime type of the file.",
            "examples": ["image/png"]
          },
          "width": {
            "title": "Width",
            "anyOf": [{ "type": "integer" }, { "type": "null" }],
            "description": "The width of the image in pixels.",
            "examples": [1024]
          },
          "url": {
            "type": "string",
            "title": "Url",
            "description": "The URL where the file can be downloaded from."
          },
          "file_name": {
            "title": "File Name",
            "anyOf": [{ "type": "string" }, { "type": "null" }],
            "description": "The name of the file. It will be auto-generated if not provided.",
            "examples": ["z9RV14K95DvU.png"]
          },
          "file_size": {
            "title": "File Size",
            "anyOf": [{ "type": "integer" }, { "type": "null" }],
            "description": "The size of the file in bytes.",
            "examples": [4404019]
          }
        },
        "required": ["url"],
        "description": "Represents an image file."
      }
    }
  },
  "paths": {
    "/fal-ai/hy-wu-edit/requests/{request_id}/status": {
      "get": {
        "parameters": [
          {
            "name": "request_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "description": "Request ID" }
          },
          {
            "name": "logs",
            "in": "query",
            "required": false,
            "schema": {
              "type": "number",
              "description": "Whether to include logs (`1`) in the response or not (`0`)."
            }
          }
        ],
        "responses": {
          "200": {
            "description": "The request status.",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/QueueStatus" } }
            }
          }
        }
      }
    },
    "/fal-ai/hy-wu-edit/requests/{request_id}/cancel": {
      "put": {
        "parameters": [
          {
            "name": "request_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "description": "Request ID" }
          }
        ],
        "responses": {
          "200": {
            "description": "The request was cancelled.",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "description": "Whether the request was cancelled successfully."
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/fal-ai/hy-wu-edit": {
      "post": {
        "requestBody": {
          "required": true,
          "content": {
            "application/json": { "schema": { "$ref": "#/components/schemas/HyWuEditInput" } }
          }
        },
        "responses": {
          "200": {
            "description": "The request status.",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/QueueStatus" } }
            }
          }
        }
      }
    },
    "/fal-ai/hy-wu-edit/requests/{request_id}": {
      "get": {
        "parameters": [
          {
            "name": "request_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "description": "Request ID" }
          }
        ],
        "responses": {
          "200": {
            "description": "Result of the request.",
            "content": {
              "application/json": { "schema": { "$ref": "#/components/schemas/HyWuEditOutput" } }
            }
          }
        }
      }
    }
  },
  "servers": [{ "url": "https://queue.fal.run" }],
  "security": [{ "apiKeyAuth": [] }]
}
