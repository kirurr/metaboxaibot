# ── Telegram ──────────────────────────────────────────────────────────────────
BOT_TOKEN=                          # required — @BotFather token
WEBAPP_URL=https://your-domain.com  # optional — Mini App URL shown in bot menu

# ── Webapp (Vite build-time) ───────────────────────────────────────────────────
VITE_API_BASE_URL=https://your-domain.com/api
VITE_BOT_USERNAME=your_bot
VITE_LEARNING_URL=https://your-learning-site.com/dashboard
VITE_METABOX_LANDING_URL=https://meta-box.ru  # Landing page for Metabox referral links

# ── Database & Cache ──────────────────────────────────────────────────────────
# Local dev: use localhost. In Docker (docker-compose): use service name as host
#   DATABASE_URL=postgresql://metabox:metabox_password@postgres:5432/metabox_db
#   REDIS_URL=redis://:your_redis_password@redis:6379
DATABASE_URL=postgresql://metabox:metabox_password@localhost:5432/metabox_db  # required
REDIS_URL=redis://localhost:6379    # required (add ?password=... if auth enabled)

# ── Metabox ecosystem integration (optional) ─────────────────────────────────
METABOX_LANDING_URL=https://meta-box.ru  # Landing page URL (used in Terms of Use links etc.)
METABOX_API_URL=https://app.meta-box.ru  # Base URL of the Metabox site
METABOX_INTERNAL_KEY=                    # Shared secret (set same value in both apps)
METABOX_SSO_SECRET=                      # HMAC secret for SSO tokens (set same in both)

# ── Web (ai.metabox.global) — новая веб-версия ──────────────────────────────
WEB_JWT_SECRET=                          # Generate: openssl rand -hex 32
WEB_ACCESS_TTL_SEC=900                   # 15 min default
WEB_REFRESH_TTL_SEC=2592000              # 30 days default
WEB_COOKIE_DOMAIN=                       # e.g. .metabox.global for prod, empty for dev
WEB_COOKIE_SECURE=                       # true/false, auto-detect by NODE_ENV if empty
WEB_FRONT_URL=https://stage.ai.metabox.global
AIBOX_BOT_USERNAME=metabox_ai_bot_test   # bot username for /start linkweb_<state> deep-link

# ── API Server ────────────────────────────────────────────────────────────────
API_PORT=3001                       # optional, default 3001
ADMIN_SECRET=                       # optional — protects /admin/* routes

# ── Observability ─────────────────────────────────────────────────────────────
NODE_ENV=development                # development | production | test
LOG_LEVEL=info                      # trace | debug | info | warn | error
SENTRY_DSN=                         # optional — Sentry error tracking DSN

# ── Docker / Deploy (prod only) ───────────────────────────────────────────────
POSTGRES_USER=metabox
POSTGRES_PASSWORD=metabox_password
POSTGRES_DB=metabox_db
REDIS_PASSWORD=
GRAFANA_PASSWORD=admin
# GitHub Container Registry — set to ghcr.io/<your-github-username>
GHCR_IMAGE_PREFIX=ghcr.io/your-github-username
# Pinned image tag — updated automatically by CD workflow on each deploy
IMAGE_TAG=latest

# ── AI Providers ──────────────────────────────────────────────────────────────
# GPT section
OPENAI_API_KEY=sk-...
OPENAI_ASSISTANT_ID=               # optional — for OpenAI Assistants API
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_AI_API_KEY=AIza...
QWEN_API_KEY=                      # optional — Qwen / Alibaba Cloud
GROK_API_KEY=                      # optional — xAI Grok
DEEPSEEK_API_KEY=                  # optional — DeepSeek

# Design / Image generation
FAL_API_KEY=                       # FAL.ai — Flux, SDXL, Midjourney proxy
FAL_ADMIN_API_KEY=                 # FAL.ai admin key — only for balance monitor (GET /account/billing); optional
REPLICATE_API_KEY=                 # Replicate — various image/video models

# Video generation
RUNWAY_API_KEY=                    # RunwayML Gen-3
LUMA_API_KEY=                      # Luma Dream Machine
HEYGEN_API_KEY=                    # HeyGen talking avatar
HEYGEN_AVATAR_ID=                  # HeyGen default avatar ID
DID_API_KEY=                       # D-ID talking head
DID_PRESENTER_URL=                 # D-ID presenter image URL
HIGGSFIELD_API_KEY=                # Higgsfield realistic human animation
HIGGSFIELD_API_SECRET=             # Higgsfield API secret

# Audio generation
ELEVENLABS_API_KEY=                # ElevenLabs TTS / voice clone / sound effects
